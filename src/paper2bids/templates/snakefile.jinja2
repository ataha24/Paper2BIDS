"""{{ title }} - Snakebids Workflow

{{ description }}

Generated by Paper2BIDS from:
{% if doi %}DOI: {{ doi }}{% endif %}
{% if repository_url %}Repository: {{ repository_url }}{% endif %}
"""

from snakebids import bids, generate_inputs

configfile: 'config/snakebids.yml'

# Generate inputs from BIDS dataset
inputs = generate_inputs(
    bids_dir=config['bids_dir'],
    pybids_inputs=config['pybids_inputs'],
    pybidsdb_dir=config.get('pybidsdb_dir'),
    pybidsdb_reset=config.get('pybidsdb_reset', False),
)

{% for input in inputs %}
# Input: {{ input.name }}
# Wildcards: {{ input.wildcards | join(', ') }}
{% endfor %}

# =============================================================================
# Target rule - defines final outputs
# =============================================================================

rule all:
    input:
        {% for step in steps %}
        {% if loop.last %}
        inputs['{{ primary_input }}'].expand(
            bids(
                root='results',
                suffix='{{ step.name }}.nii.gz',
                **inputs['{{ primary_input }}'].wildcards
            ),
        ),
        {% endif %}
        {% endfor %}
    default_target: True


# =============================================================================
# Processing Rules
# =============================================================================
{% for step in steps %}

rule {{ step.name }}:
    """{{ step.description }}"""
    input:
        {% if loop.first %}
        inputs['{{ primary_input }}'].path,
        {% else %}
        rules.{{ steps[loop.index0 - 1].name }}.output,
        {% endif %}
    output:
        bids(
            root='results',
            suffix='{{ step.name }}.nii.gz',
            **inputs['{{ primary_input }}'].wildcards
        ),
    {% if step.parameters %}
    params:
        {% for key, value in step.parameters.items() %}
        {{ key }}=config.get('{{ key }}', {{ value | repr }}),
        {% endfor %}
    {% endif %}
    {% if step.software %}
    # Software: {{ step.software }}
    {% endif %}
    {% if step.command %}
    shell:
        '{{ step.command }}'
    {% else %}
    shell:
        """
        # TODO: Implement {{ step.name }}
        # {{ step.description }}
        cp {input} {output}
        """
    {% endif %}
{% endfor %}
