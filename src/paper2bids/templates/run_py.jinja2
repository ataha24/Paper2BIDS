from pathlib import Path

from snakebids import bidsapp, plugins


def get_app():
    """Create and configure the BIDS app."""
    return bidsapp.app(
        [
            plugins.SnakemakeBidsApp(Path(__file__).resolve().parent),
        ]
    )


app = get_app()


if __name__ == "__main__":
    app.run()
