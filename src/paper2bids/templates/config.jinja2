# {{ title }} - Snakebids Configuration
#
# {{ description }}
#
# Generated by Paper2BIDS
{% if doi %}# DOI: {{ doi }}{% endif %}
{% if repository_url %}# Repository: {{ repository_url }}{% endif %}

# =============================================================================
# BIDS Input Configuration
# =============================================================================

bids_dir: '/path/to/bids/dataset'

pybids_inputs:
{% for input in inputs %}
  {{ input.name }}:
    filters:
{% for key, value in input.filters.items() %}
      {{ key }}: '{{ value }}'
{% endfor %}
    wildcards:
{% for wildcard in input.wildcards %}
      - {{ wildcard }}
{% endfor %}
{% endfor %}

# =============================================================================
# PyBIDS Caching (optional, speeds up repeated runs)
# =============================================================================

pybidsdb_dir: '.pybids_cache'
pybidsdb_reset: false

# =============================================================================
# BIDS App Configuration
# =============================================================================

analysis_levels:
{% for level in analysis_levels %}
  - {{ level }}
{% endfor %}

targets_by_analysis_level:
{% for level in analysis_levels %}
  {{ level }}:
    - ''  # Empty string targets the 'all' rule
{% endfor %}

# =============================================================================
# Command Line Arguments
# =============================================================================

parse_args:
{% for param_name, param_config in cli_parameters.items() %}
  {{ param_name }}:
{% for key, value in param_config.items() %}
{% if value is string %}
    {{ key }}: '{{ value }}'
{% elif value is iterable and value is not string %}
    {{ key }}:
{% for item in value %}
      - {{ item }}
{% endfor %}
{% else %}
    {{ key }}: {{ value }}
{% endif %}
{% endfor %}
{% endfor %}

# =============================================================================
# Pipeline Parameters
# =============================================================================
{% for step in steps %}
{% if step.parameters %}

# {{ step.name }} parameters
{% for key, value in step.parameters.items() %}
{{ key }}: {{ value }}
{% endfor %}
{% endif %}
{% endfor %}

# =============================================================================
# Debug Mode
# =============================================================================

debug: false
