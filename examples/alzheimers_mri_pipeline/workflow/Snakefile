rule surfstat_vbm_analysis:
    """Performs statistical analysis comparing two groups using SurfStat for VBM data, computing t-statistics, p-values, q-values, and effect sizes for both directions of comparison."""
    input:
        rules.test_input_orientation.output,
    output:
        bids(
            root='results',
            suffix='surfstat_vbm_analysis.nii.gz',
            **inputs['bold'].wildcards
        ),
    params:
        contrast=config.get('contrast', 'fa'),
        fa_thresh=config.get('fa_thresh', '0.27'),
        group1_name=config.get('group1_name', 'control'),
        group2_name=config.get('group2_name', 'treatment'),
        input_dir=config.get('input_dir', '.'),
        output_dir=config.get('output_dir', 'results'),
    shell:
        'matlab -nodisplay -nosplash -r "surfstat_for_vbm_pipeline('{params.contrast}','{input.mask}','{params.input_dir}','{params.output_dir}','{params.group1_name}','{params.group2_name}','{params.group1_files}','{params.group2_files}'); exit"'

