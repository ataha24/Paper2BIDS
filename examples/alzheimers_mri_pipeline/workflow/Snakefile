        timeout_s=config.get('timeout_s', '5.0'),
        output=config.get('output', 'None (optional output directory or filename)'),
    shell:
        'python {script}'

rule create_centered_mass:
    """Creates a binary mask NIfTI image with a centered cubic region of ones surrounded by zeros. The cube size is determined by dividing the image dimensions by a fraction factor (default 4)."""
    input:
        rules.create_identity_warp.output,
    output:
        bids(
            root='results',
            suffix='create_centered_mass.nii.gz',
            **inputs['input'].wildcards
        ),
    params:
        frac=config.get('frac', '4'),
    shell:
        'python {script} {input.input_nifti} {output.output_mask_nifti} --frac {params.frac}'

