        timeout_s=config.get('timeout_s', '5.0'),
    shell:
        'python {script}'

rule create_centered_mass:
    """Creates a binary mask NIfTI image with a centered cube of 1s surrounded by 0s, where the cube size is determined as a fraction of the input image dimensions."""
    input:
        rules.create_identity_warp.output,
    output:
        bids(
            root='results',
            suffix='create_centered_mass.nii.gz',
            **inputs['bold'].wildcards
        ),
    params:
        frac=config.get('frac', '4'),
    shell:
        'python {script}'

rule create_identity_warp:
    """Creates a zero displacement field (identity warp) from an input NIfTI image with vector intent for registration purposes. Outputs a 5D NIfTI with displacement vectors matching the input image dimensions."""
    input:
        rules.create_centered_mass.output,
    output:
        bids(
            root='results',
            suffix='create_identity_warp.nii.gz',
            **inputs['bold'].wildcards
        ),
    params:
        dtype=config.get('dtype', 'float64'),
        timeout_s=config.get('timeout_s', '5.0'),
        default_name=config.get('default_name', 'identity_warp'),
        default_ext=config.get('default_ext', '.nii.gz'),
    shell:
        'python -c "from samba_py.nifti_warp import create_identity_warp; create_identity_warp('{input.input_nifti}', '{output.identity_warp_nifti}', dtype='{params.dtype}', timeout_s={params.timeout_s})"'

rule skull_strip_brain:
    """Performs skull stripping on NIfTI images using FSL BET and optionally ANTs brain extraction to remove non-brain tissue."""
    input:
        rules.create_identity_warp.output,
    output:
        bids(
            root='results',
            suffix='skull_strip_brain.nii.gz',
            **inputs['bold'].wildcards
        ),
    params:
        bet_fractional_intensity=config.get('bet_fractional_intensity', '0.3'),
        bet_gradient=config.get('bet_gradient', '0'),
        bet_robust=config.get('bet_robust', 'True'),
        bet_mask=config.get('bet_mask', 'True'),
        use_ants=config.get('use_ants', 'True'),
    shell:
        'bash {input.script}'

rule test_input_orientation:
